---
import type { SiteTheme } from "../types/siteTheme";

interface Props {
  variation: SiteTheme;
}

const { variation } = Astro.props;
const doorCount = Math.max(20, Math.round(variation.density * 21));
const laneAngles = [-168, -134, -111, -78, -43, -18, 17, 39, 76, 118, 151].map(
  (angle) => (angle * Math.PI) / 180
);
const doors = Array.from({ length: doorCount }, (_, index) => {
  const angle = laneAngles[(index * 7) % laneAngles.length] + ((index % 4) - 1.5) * 0.055;
  const centerX = 52;
  const centerY = 43;
  const startRadius = 2.8 + (index % 4) * 1.55;
  const exitRadius = 72 + ((index * 3) % 6) * 5.2;
  const startX = centerX + Math.cos(angle) * startRadius;
  const startY = centerY + Math.sin(angle) * startRadius * 0.7;
  const exitX = centerX + Math.cos(angle) * exitRadius;
  const exitY = centerY + Math.sin(angle) * exitRadius * 0.82 + 10;
  const dx2 = exitX - startX;
  const dy2 = exitY - startY;
  const scale = 0.5 + ((index * 11) % 10) / 16;
  const depth = 0.68 + ((index * 5) % 7) / 11;
  const startScale = 0.08 + depth * 0.04;
  const exitScale = scale * (depth + 0.72);
  const scaleRange = exitScale - startScale;
  const dxA = dx2 * 0.08;
  const dyA = dy2 * 0.08;
  const dxB = dx2 * 0.2;
  const dyB = dy2 * 0.2;
  const dxC = dx2 * 0.38;
  const dyC = dy2 * 0.38;
  const dxD = dx2 * 0.58;
  const dyD = dy2 * 0.58;
  const dxE = dx2 * 0.76;
  const dyE = dy2 * 0.76;
  const dxF = dx2 * 0.91;
  const dyF = dy2 * 0.91;
  const scaleA = startScale + scaleRange * 0.08;
  const scaleB = startScale + scaleRange * 0.2;
  const scaleC = startScale + scaleRange * 0.38;
  const scaleD = startScale + scaleRange * 0.58;
  const scaleE = startScale + scaleRange * 0.76;
  const scaleF = startScale + scaleRange * 0.91;
  const rotate = ((index * 13) % 18) - 9 + variation.tilt * 0.25;
  const travel = 30;
  const delay = -((index * 4.73) % travel);
  const openPattern = [0, 18, 42, 7, 56, 28, 0, 50, 12, 36, 60];
  const open = openPattern[index % openPattern.length];
  const openSoft = open * 0.22;
  const openHalf = open * 0.35;
  const openWide = open * 0.82;
  const openNarrow = open * 0.14;
  const leafOffset = -((index * 1.67) % 7.5);
  return {
    index,
    startX,
    startY,
    exitX,
    exitY,
    dx2,
    dy2,
    dxA,
    dyA,
    dxB,
    dyB,
    dxC,
    dyC,
    dxD,
    dyD,
    dxE,
    dyE,
    dxF,
    dyF,
    startScale,
    scaleA,
    scaleB,
    scaleC,
    scaleD,
    scaleE,
    scaleF,
    exitScale,
    rotate,
    travel,
    delay,
    open,
    openSoft,
    openHalf,
    openWide,
    openNarrow,
    leafOffset,
  };
});
---

<div class="backdoor-sky" aria-hidden="true">
  <div class="moon-veil"></div>
  <div class="manifest-glow"></div>
  <div class="door-layer">
    {
      doors.map((door) => (
        <span
          class="floating-door"
          style={`--sx:${door.startX}%; --sy:${door.startY}%; --dx-a:${door.dxA}vw; --dy-a:${door.dyA}vh; --dx-b:${door.dxB}vw; --dy-b:${door.dyB}vh; --dx-c:${door.dxC}vw; --dy-c:${door.dyC}vh; --dx-d:${door.dxD}vw; --dy-d:${door.dyD}vh; --dx-e:${door.dxE}vw; --dy-e:${door.dyE}vh; --dx-f:${door.dxF}vw; --dy-f:${door.dyF}vh; --dx2:${door.dx2}vw; --dy2:${door.dy2}vh; --ss:${door.startScale}; --sa:${door.scaleA}; --sb:${door.scaleB}; --sc:${door.scaleC}; --sd:${door.scaleD}; --se:${door.scaleE}; --sf:${door.scaleF}; --es:${door.exitScale}; --r:${door.rotate}deg; --travel:${door.travel}s; --delay:${door.delay.toFixed(2)}s; --leaf-offset:${door.leafOffset.toFixed(2)}s; --open:${door.open}deg; --open-soft:${door.openSoft.toFixed(2)}deg; --open-half:${door.openHalf.toFixed(2)}deg; --open-wide:${door.openWide.toFixed(2)}deg; --open-narrow:${door.openNarrow.toFixed(2)}deg; --close:${-door.open}deg; --close-soft:${(-door.openSoft).toFixed(2)}deg; --close-half:${(-door.openHalf).toFixed(2)}deg; --close-wide:${(-door.openWide).toFixed(2)}deg; --close-narrow:${(-door.openNarrow).toFixed(2)}deg;`}
        >
          <span class="door-slab"></span>
        </span>
      ))
    }
  </div>
  <div class="grain-layer"></div>
</div>
