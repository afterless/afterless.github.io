---
import type { SiteTheme } from "../types/siteTheme";

interface Props {
  variation: SiteTheme;
}

const { variation } = Astro.props;
const doorCount = Math.max(20, Math.round(variation.density * 21));
const laneAngles = [-168, -134, -111, -78, -43, -18, 17, 39, 76, 118, 151].map(
  (angle) => (angle * Math.PI) / 180
);
const doors = Array.from({ length: doorCount }, (_, index) => {
  const angle = laneAngles[(index * 7) % laneAngles.length] + ((index % 4) - 1.5) * 0.055;
  const centerX = 52;
  const centerY = 43;
  const startRadius = 2.8 + (index % 4) * 1.55;
  const exitRadius = 72 + ((index * 3) % 6) * 5.2;
  const startX = centerX + Math.cos(angle) * startRadius;
  const startY = centerY + Math.sin(angle) * startRadius * 0.7;
  const exitX = centerX + Math.cos(angle) * exitRadius;
  const exitY = centerY + Math.sin(angle) * exitRadius * 0.82 + 10;
  const dx2 = exitX - startX;
  const dy2 = exitY - startY;
  const scale = 0.5 + ((index * 11) % 10) / 16;
  const depth = 0.68 + ((index * 5) % 7) / 11;
  const startScale = 0.08 + depth * 0.04;
  const exitScale = scale * (depth + 0.72);
  const midProgress = 0.58;
  const midX = dx2 * midProgress;
  const midY = dy2 * midProgress;
  const midScale = startScale + (exitScale - startScale) * midProgress;
  const rotate = ((index * 13) % 18) - 9 + variation.tilt * 0.25;
  const travel = 30;
  const delay = -((index * 4.73) % travel);
  const openPattern = [0, 18, 42, 7, 56, 28, 0, 50, 12, 36, 60];
  const open = openPattern[index % openPattern.length];
  const openSoft = open * 0.22;
  const openHalf = open * 0.35;
  const openWide = open * 0.82;
  const openNarrow = open * 0.14;
  const leafOffset = -((index * 1.67) % 7.5);
  return {
    index,
    startX,
    startY,
    exitX,
    exitY,
    dx2,
    dy2,
    midX,
    midY,
    startScale,
    midScale,
    exitScale,
    rotate,
    travel,
    delay,
    open,
    openSoft,
    openHalf,
    openWide,
    openNarrow,
    leafOffset,
  };
});
---

<div class="backdoor-sky" aria-hidden="true">
  <div class="moon-veil"></div>
  <div class="manifest-glow"></div>
  <div class="door-layer">
    {
      doors.map((door) => (
        <span
          class="floating-door"
          style={`--sx:${door.startX}%; --sy:${door.startY}%; --dx:${door.dx2}vw; --dy:${door.dy2}vh; --mid-x:${door.midX}vw; --mid-y:${door.midY}vh; --ss:${door.startScale}; --mid-scale:${door.midScale}; --es:${door.exitScale}; --r:${door.rotate}deg; --travel:${door.travel}s; --delay:${door.delay.toFixed(2)}s; --leaf-offset:${door.leafOffset.toFixed(2)}s; --open:${door.open}deg; --open-soft:${door.openSoft.toFixed(2)}deg; --open-half:${door.openHalf.toFixed(2)}deg; --open-wide:${door.openWide.toFixed(2)}deg; --open-narrow:${door.openNarrow.toFixed(2)}deg; --close:${-door.open}deg; --close-soft:${(-door.openSoft).toFixed(2)}deg; --close-half:${(-door.openHalf).toFixed(2)}deg; --close-wide:${(-door.openWide).toFixed(2)}deg; --close-narrow:${(-door.openNarrow).toFixed(2)}deg;`}
        >
          <span class="door-slab"></span>
        </span>
      ))
    }
  </div>
  <div class="grain-layer"></div>
</div>
