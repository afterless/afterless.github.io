---
interface Props {
  label?: string;
  class?: string;
  projection?: "default" | "focus";
}

type QuestionStar = {
  name: string;
  x: number;
  y: number;
  question: string;
  filter: string;
};

const questionStars: QuestionStar[] = [
  {
    name: "Dubhe",
    x: 18,
    y: 28,
    question: "What keeps recurring across projects?",
    filter: "meta",
  },
  {
    name: "Merak",
    x: 12,
    y: 64,
    question: "Where would control fail first?",
    filter: "control",
  },
  {
    name: "Phecda",
    x: 39,
    y: 72,
    question: "Which assumptions are load-bearing?",
    filter: "research",
  },
  {
    name: "Megrez",
    x: 45,
    y: 39,
    question: "What is weakly evidenced?",
    filter: "interpretability",
  },
  {
    name: "Alioth",
    x: 61,
    y: 33,
    question: "Which sources changed the model?",
    filter: "canon",
  },
  {
    name: "Mizar",
    x: 75,
    y: 42,
    question: "What belongs on the public surface?",
    filter: "essay",
  },
  {
    name: "Alkaid",
    x: 88,
    y: 54,
    question: "What should remain only a route marker?",
    filter: "fragment",
  },
];

const questionPolyline = "18,28 12,64 39,72 45,39 18,28 45,39 61,33 75,42 88,54";

const { label = "Question map", class: className = "", projection = "default" } = Astro.props;

function projectForFocus(x: number, y: number) {
  return {
    x: 8 + ((x - 12) / 76) * 84,
    y: 12 + ((y - 28) / 44) * 76,
  };
}

function formatPoint(value: number) {
  return Number(value.toFixed(2));
}

const displayStars =
  projection === "focus"
    ? questionStars.map((star) => ({ ...star, ...projectForFocus(star.x, star.y) }))
    : questionStars;

const starByName = new Map(displayStars.map((star) => [star.name, star]));
const polylineOrder = ["Dubhe", "Merak", "Phecda", "Megrez", "Dubhe", "Megrez", "Alioth", "Mizar", "Alkaid"];
const displayPolyline =
  projection === "focus"
    ? polylineOrder
        .map((name) => {
          const star = starByName.get(name);
          return star ? `${formatPoint(star.x)},${formatPoint(star.y)}` : "";
        })
        .filter(Boolean)
        .join(" ")
    : questionPolyline;
---

<div class={`question-seal ${className}`} aria-label={label}>
  <svg viewBox="0 0 100 100" preserveAspectRatio="none" role="img" aria-label="Seven-star question map">
    <polyline points={displayPolyline}></polyline>
  </svg>
  {
    displayStars.map((star) => (
      <button
        type="button"
        style={`--star-x:${star.x}%; --star-y:${star.y}%;`}
        data-star={star.name}
        data-star-filter={star.filter}
        data-question-text={star.question}
        aria-label={`${star.name}: ${star.question}`}
      >
        <span>{star.name}</span>
      </button>
    ))
  }
</div>
