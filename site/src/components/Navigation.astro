---
const pathname = Astro.url.pathname;
const links = [
  { href: "/blog", label: "blog" },
  { href: "/projects", label: "projects" },
];
---

<header
  class="subpage-nav fixed top-0 left-0 right-0 z-50 border-b border-stone-200/70 bg-stone-50/82 backdrop-blur-md dark:border-stone-800/80 dark:bg-stone-950/82"
>
  <nav class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-6 py-4">
    <a
      href="/"
      class="grid text-neutral-900 transition-colors hover:text-accent dark:text-stone-50"
    >
      <span class="text-base font-semibold tracking-tight">Ayush Panda</span>
      <span class="font-mono text-[0.68rem] text-stone-500 dark:text-stone-400">afterless</span>
    </a>
    <div class="flex items-center gap-4 sm:gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm transition-colors",
              pathname.startsWith(link.href)
                ? "text-accent font-medium"
                : "text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
