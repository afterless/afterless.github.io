---
import MainLayout from "../../layouts/MainLayout.astro";
import QuestionSeal from "../../components/QuestionSeal.astro";

const selectedStudies = [
  ["Front Room / Back Room", "public surface plus private working chamber"],
  ["Koku-Beya Archive", "dense archive rows with context behind each entry"],
  ["Secret Liturgy Notes", "cruxes, assumptions, and compressed argument layers"],
  ["Bamboo / Myoga Motif", "paired organic marks for separators and state changes"],
  ["Night of Manifestation", "dark mode as the canonical reading state"],
  ["One-Person Transmission", "personal canon and intellectual lineage"],
  ["Henbai Footsteps", "scroll progress as stepped marginal motion"],
  ["Clouded Seven-Star Seal", "rare sequence mark, never background decoration"],
  ["Backdoor Search", "command/search chamber grouped by artifact type"],
  ["Mirror-Star Altar", "question maps for synthesis and sequence pages"],
];

const archiveRows = [
  {
    kind: "essay",
    title: "Control evaluations for automated AI R&D",
    state: "public",
    hidden: "cruxes hidden",
    question: "Merak",
  },
  {
    kind: "note",
    title: "Mechanistic stories I currently distrust",
    state: "working",
    hidden: "assumptions open",
    question: "Megrez",
  },
  {
    kind: "canon",
    title: "Posts that changed my model of agency",
    state: "lineage",
    hidden: "linked outward",
    question: "Alioth",
  },
  {
    kind: "map",
    title: "Questions that keep returning",
    state: "sequence",
    hidden: "star seal",
    question: "Dubhe",
  },
];

const chambers = [
  ["front", "Readable essay surface"],
  ["back", "Private crux layer"],
  ["store", "Archive and search"],
  ["mirror", "Question map"],
];

const footsteps = [
  ["01", "statement", "Thesis"],
  ["02", "rooms", "Rooms"],
  ["03", "archive", "Archive"],
  ["04", "back-room", "Back room"],
  ["05", "system", "Rules"],
];

---

<MainLayout title="synthesis study — afterless" description="A synthesized design direction for the site." wide>
  <article class="synthesis-page">
    <nav class="sauce-return" aria-label="Design study navigation">
      <a href="/design-studies">All studies</a>
      <span>Synthesis candidate</span>
      <a href="/design-studies/front-room-back-room">Front room</a>
      <a href="/design-studies/mirror-star-altar">Mirror-star</a>
    </nav>

    <header class="synthesis-hero">
      <p class="subpage-kicker">Synthesis candidate</p>
      <h1>Inner Archive</h1>
      <p>
        A personal research site with a calm public room, a hidden working room,
        a serious archive, and rare symbolic marks that only appear when they
        organize the reader's movement.
      </p>
    </header>

    <section class="synthesis-canvas" aria-label="Synthesized prototype">
      <aside class="synthesis-left-rail" aria-label="Prototype section navigation">
        <p>Footsteps</p>
        {
          footsteps.map(([number, target, label], footIndex) => (
            <button
              type="button"
              class:list={[footIndex === 0 && "is-active"]}
              data-footstep={target}
              aria-label={`Jump to ${label}`}
            >
              {number}
            </button>
          ))
        }
      </aside>

      <div class="synthesis-front-room">
        <div class="synthesis-topbar">
          <span>Ayush Panda</span>
          <button type="button" data-backroom-search-toggle aria-expanded="false" aria-controls="backroom-search">
            search the back room
          </button>
        </div>

        <div class="backroom-search" id="backroom-search" hidden>
          <label>
            <span>Search layer</span>
            <input type="search" placeholder="try control, canon, question, crux" data-backroom-search />
          </label>
          <div class="backroom-search-results" aria-live="polite">
            {
              archiveRows.map((row) => (
                <a href="#archive" data-search-result={`${row.kind} ${row.title} ${row.state} ${row.hidden} ${row.question}`.toLowerCase()}>
                  <span>{row.kind}</span>
                  <strong>{row.title}</strong>
                  <em>{row.question}</em>
                </a>
              ))
            }
          </div>
        </div>

        <section class="synthesis-statement" id="statement" data-footstep-section="statement">
          <div class="paired-mark" aria-hidden="true"></div>
          <p>current shape</p>
          <h2>Control, interpretability, and agentic systems.</h2>
          <p>
            The front page stays direct and useful. The interesting depth is not
            another visual layer; it is a second reading layer for cruxes,
            lineage, and search.
          </p>
        </section>

        <section class="synthesis-room-grid" id="rooms" data-footstep-section="rooms" aria-label="Site rooms">
          {
            chambers.map(([label, text]) => (
              <div>
                <span>{label}</span>
                <p>{text}</p>
              </div>
            ))
          }
        </section>

        <section class="synthesis-archive" id="archive" data-footstep-section="archive" aria-label="Archive prototype">
          <div class="synthesis-section-head">
            <p>archive</p>
          </div>
          {
            archiveRows.map((row) => (
              <article data-question={row.question}>
                <span>{row.kind}</span>
                <div>
                  <h3>{row.title}</h3>
                  <p>{row.state} / {row.hidden}</p>
                </div>
              </article>
            ))
          }
        </section>
      </div>

      <aside class="synthesis-back-room" id="back-room" data-footstep-section="back-room">
        <QuestionSeal class="mirror-seal" />
        <p class="synthesis-side-label">hidden layer</p>
        <h2>Cruxes, assumptions, and lineage.</h2>
        <p data-question-display>
          Hover a star to inspect one recurring question.
        </p>
        <dl>
          <div>
            <dt>status</dt>
            <dd>draftable, revisable, explicit</dd>
          </div>
          <div>
            <dt>canon</dt>
            <dd>sources tracked by model-change, not prestige</dd>
          </div>
          <div>
            <dt>search</dt>
            <dd>grouped by essays, notes, maps, tools</dd>
          </div>
        </dl>
      </aside>
    </section>

    <section class="synthesis-system" id="system" data-footstep-section="system">
      <div>
        <h2>Core Rule</h2>
        <p>
          The theme should govern information architecture first and ornament
          second. Hiddenness becomes drafts, cruxes, search, and lineage.
        </p>
      </div>
      <div>
        <h2>Visual Rule</h2>
        <p>
          Use paired botanical marks, stepped margins, warm dark reading color,
          and rare star seals. No constant symbolic wallpaper.
        </p>
      </div>
      <div>
        <h2>Product Rule</h2>
        <p>
          Every beautiful element should also help navigation, confidence,
          search, citation, or revision.
        </p>
      </div>
    </section>

    <section class="synthesis-sources">
      <h2>Included Studies</h2>
      <div>
        {
          selectedStudies.map(([title, role]) => (
            <p><strong>{title}</strong> <span>{role}</span></p>
          ))
        }
      </div>
    </section>
  </article>

  <script>
    const footstepButtons = [...document.querySelectorAll("[data-footstep]")];
    const footstepSections = [...document.querySelectorAll("[data-footstep-section]")];

    footstepButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const target = document.querySelector(`[data-footstep-section="${button.dataset.footstep}"]`);
        target?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    const footstepObserver = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (!visible) return;

        footstepButtons.forEach((button) => {
          button.classList.toggle("is-active", button.dataset.footstep === visible.target.dataset.footstepSection);
        });
      },
      { rootMargin: "-22% 0px -58% 0px", threshold: [0.15, 0.35, 0.6] },
    );

    footstepSections.forEach((section) => footstepObserver.observe(section));

    const searchToggle = document.querySelector("[data-backroom-search-toggle]");
    const searchPanel = document.querySelector("#backroom-search");
    const searchInput = document.querySelector("[data-backroom-search]");
    const searchResults = [...document.querySelectorAll("[data-search-result]")];

    searchToggle?.addEventListener("click", () => {
      const willOpen = searchPanel?.hasAttribute("hidden");
      searchPanel?.toggleAttribute("hidden", !willOpen);
      searchToggle.setAttribute("aria-expanded", String(willOpen));
      if (willOpen) searchInput?.focus();
    });

    searchInput?.addEventListener("input", () => {
      const query = searchInput.value.trim().toLowerCase();
      searchResults.forEach((result) => {
        result.toggleAttribute("hidden", query.length > 0 && !result.dataset.searchResult?.includes(query));
      });
    });

    const starButtons = [...document.querySelectorAll("[data-star]")];
    const questionDisplay = document.querySelector("[data-question-display]");
    const archiveEntries = [...document.querySelectorAll("[data-question]")];
    const defaultQuestionText = questionDisplay?.textContent?.trim() ?? "";

    function activateStar(button) {
      starButtons.forEach((star) => star.classList.toggle("is-active", star === button));
      questionDisplay?.classList.add("is-visible");
      if (questionDisplay && button.dataset.questionText) {
        questionDisplay.textContent = button.dataset.questionText;
      }

      archiveEntries.forEach((entry) => {
        entry.classList.toggle("is-linked-question", entry.dataset.question === button.dataset.star);
      });
    }

    function clearStars() {
      starButtons.forEach((star) => star.classList.remove("is-active"));
      archiveEntries.forEach((entry) => entry.classList.remove("is-linked-question"));
      questionDisplay?.classList.remove("is-visible");
      if (questionDisplay) questionDisplay.textContent = defaultQuestionText;
    }

    starButtons.forEach((button) => {
      button.addEventListener("mouseenter", () => activateStar(button));
      button.addEventListener("focus", () => activateStar(button));
      button.addEventListener("blur", clearStars);
    });

    document.querySelector(".mirror-seal")?.addEventListener("mouseleave", clearStars);
  </script>
</MainLayout>
