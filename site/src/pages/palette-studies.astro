function cssVars(study: PaletteStudy) {
  return [
    `--ink:${study.ink}`,
    `--paper:${study.paper}`,
    `--panel:${study.panel}`,
    `--text:${study.text}`,
    `--muted:${study.muted}`,
    `--accent:${study.accent}`,
    `--accent-two:${study.accentTwo}`,
    `--door:${study.door}`,
    `--glow:${study.glow}`,
    `--site-shadow:${study.shadow}`,
    `--grain-opacity:${study.grain}`,
  ].join(";");
}
---

<DocumentLayout
  title="Palette studies - afterless"
  description="Dark color studies for afterless."
>
  <main class="palette-studies">
    <header class="palette-study-header">
      <a href="/">afterless</a>
      <p>Twenty-four dark directions for the site palette.</p>
      <h1>Palette studies</h1>
    </header>

    <section class="palette-grid" aria-label="Color studies">
      {
        paletteStudies.map((study, index) => (
          <article class="palette-card" style={cssVars(study)}>
            <div class="palette-preview" aria-hidden="true">
              <span class="palette-door palette-door-a"></span>
              <span class="palette-door palette-door-b"></span>
              <span class="palette-door palette-door-c"></span>
              <div class="palette-mini-panel">
                <span>{String(index + 1).padStart(2, "0")}</span>
                <strong>{study.name}</strong>
                <p>{study.mode}</p>
              </div>
            </div>
            <div class="palette-card-body">
              <h2>{study.name}</h2>
              <p>{study.principle}</p>
              <small>{study.note}</small>
              <div class="palette-swatches" aria-label={`${study.name} swatches`}>
                <span style={`--swatch:${study.ink}`} title="ink"></span>
                <span style={`--swatch:${study.paper}`} title="paper"></span>
                <span style={`--swatch:${study.text}`} title="text"></span>
                <span style={`--swatch:${study.muted}`} title="muted"></span>
                <span style={`--swatch:${study.accent}`} title="accent"></span>
                <span style={`--swatch:${study.accentTwo}`} title="secondary"></span>
                <span style={`--swatch:${study.door}`} title="door"></span>
              </div>
            </div>
          </article>
        ))
      }
    </section>
  </main>
</DocumentLayout>
