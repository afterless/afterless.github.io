---
import DocumentLayout from "../../../layouts/DocumentLayout.astro";
import LandingPage from "../../../components/LandingPage.astro";
import { getCollection } from "astro:content";
import { cssVars, selectedThemePreviews } from "../../../lib/themes";
import "../../../styles/theme-previews.css";

export async function getStaticPaths() {
  return selectedThemePreviews.map((theme) => ({
    params: { theme: theme.id },
    props: { theme },
  }));
}

const { theme } = Astro.props;
const posts = (await getCollection("blog"))
  .filter((post) => post.data.draft !== true)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const recentPosts = posts.slice(0, 4).map((post) => ({
  title: post.data.title,
  date: post.data.date,
  tag: post.data.tags?.[0] ?? "essay",
  summary: post.data.description,
  href: post.id === "a-toy-control-eval" ? `/theme-previews/${theme.id}/blog/a-toy-control-eval/` : `/blog/${post.id}`,
  search: `${post.data.title} ${post.data.description} ${(post.data.tags ?? []).join(" ")}`.toLowerCase(),
}));

const workItems = [
  "MATS scholar in Francis Rhys Ward's stream, focused on AI control for automated AI R&D.",
  "MSCS student at Georgia Tech and co-founder of the Georgia Tech AI Safety Initiative.",
  "Previous work on sparse autoencoders, future-token representations, ML safety teaching, and software engineering at AWS.",
];
---

<DocumentLayout
  title={`${theme.name} landing preview - afterless`}
  description={`Landing page preview for ${theme.name}.`}
>
  <aside class="theme-preview-ribbon" style={cssVars(theme)}>
    <a href="/theme-previews/">all previews</a>
    <span>{theme.name}</span>
    <a href={`/theme-previews/${theme.id}/blog/a-toy-control-eval/`}>article</a>
  </aside>
  <LandingPage siteTheme={theme} recentPosts={recentPosts} workItems={workItems} />
</DocumentLayout>
