---
import DocumentLayout from "../../../../layouts/DocumentLayout.astro";
import { getCollection, render } from "astro:content";
import { cssVars, selectedThemePreviews } from "../../../../lib/themes";
import "../../../../styles/theme-previews.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const post = posts.find((item) => item.id === "a-toy-control-eval");
  if (!post) return [];

  return selectedThemePreviews.map((theme) => ({
    params: { theme: theme.id },
    props: { theme, post },
  }));
}

const { theme, post } = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const readingMinutes = Math.max(1, Math.round(post.body.split(/\s+/).length / 220));
const outline = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<DocumentLayout
  title={`${theme.name} article preview - afterless`}
  description={`A Toy Control Eval preview using ${theme.name}.`}
>
  <div class="theme-preview-shell" style={cssVars(theme)}>
    <aside class="theme-preview-ribbon">
      <a href="/theme-previews/">all previews</a>
      <span>{theme.name}</span>
      <a href={`/theme-previews/${theme.id}/landing/`}>landing</a>
    </aside>

    <main class="theme-preview-article-main">
      <article class="essay-shell">
        <header class="essay-header">
          <a href="/theme-previews/" class="essay-back"><span aria-hidden="true">←</span> Back to previews</a>
          <h1>{post.data.title}</h1>
          <p class="essay-description">{post.data.description}</p>
          <div class="essay-meta">
            <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
            <span>{readingMinutes} min read</span>
          </div>
        </header>

        <div class="essay-grid">
          <aside class="essay-side" aria-label="Article outline">
            <div class="essay-outline">
              <p>Outline</p>
              {
                outline.length > 0 ? (
                  <nav>
                    {outline.map((heading) => (
                      <a
                        class:list={[heading.depth === 3 && "is-child"]}
                        href={`#${heading.slug}`}
                        data-outline-link={heading.slug}
                      >
                        {heading.text}
                      </a>
                    ))}
                  </nav>
                ) : (
                  <span>No headings yet.</span>
                )
              }
            </div>
          </aside>

          <div class="essay-content">
            <Content />
          </div>
        </div>

        <footer class="essay-end">
          <a href="/theme-previews/">Back to previews</a>
          <a href={`/theme-previews/${theme.id}/landing/`}>Landing preview</a>
        </footer>
      </article>
    </main>
  </div>

  <script>
    const outlineLinks = [...document.querySelectorAll("[data-outline-link]")];
    const headings = outlineLinks
      .map((link) => {
        const id = link.getAttribute("data-outline-link");
        const heading = id ? document.getElementById(id) : null;
        return heading ? { link, heading } : null;
      })
      .filter(Boolean);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (!visible) return;

        headings.forEach((item) => {
          item?.link.classList.toggle("is-active", item.heading === visible.target);
        });
      },
      { rootMargin: "-18% 0px -65% 0px", threshold: [0.1, 0.35, 0.65] },
    );

    headings.forEach((item) => item && observer.observe(item.heading));
  </script>
</DocumentLayout>
