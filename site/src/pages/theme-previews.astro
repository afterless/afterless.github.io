---
import DocumentLayout from "../layouts/DocumentLayout.astro";
import { selectedThemePreviews } from "../lib/themes";
import "../styles/theme-previews.css";
---

<DocumentLayout title="Theme previews - afterless" description="Landing and article theme previews for afterless.">
  <main class="theme-preview-index">
    <header>
      <a href="/palette-studies/">palette studies</a>
      <p>Landing and article previews for the shortlisted palettes.</p>
      <h1>Theme previews</h1>
    </header>
    <section aria-label="Shortlisted palettes">
      {
        selectedThemePreviews.map((theme) => (
          <article style={`--ink:${theme.ink};--paper:${theme.paper};--panel:${theme.panel};--text:${theme.text};--muted:${theme.muted};--accent:${theme.accent};--accent-two:${theme.accentTwo};--door:${theme.door};--glow:${theme.glow};--site-shadow:${theme.shadow};--grain-opacity:${theme.grain}`}>
            <div>
              <span>{theme.mode}</span>
              <h2>{theme.name}</h2>
              <p>{theme.principle}</p>
            </div>
            <nav>
              <a href={`/theme-previews/${theme.id}/landing/`}>landing</a>
              <a href={`/theme-previews/${theme.id}/blog/a-toy-control-eval/`}>toy control eval</a>
            </nav>
          </article>
        ))
      }
    </section>
  </main>
</DocumentLayout>
