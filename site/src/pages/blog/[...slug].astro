---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) => post.data.draft !== true);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const readingMinutes = Math.max(1, Math.round(post.body.split(/\s+/).length / 220));
const outline = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<MainLayout title={`${post.data.title} — afterless`} description={post.data.description} wide>
  <article class="essay-shell">
    <header class="essay-header">
      <a href="/blog" class="essay-back"><span aria-hidden="true">←</span> Back to blog</a>
      <h1>{post.data.title}</h1>
      <p class="essay-description">{post.data.description}</p>
      <div class="essay-meta">
        <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
        <span>{readingMinutes} min read</span>
      </div>
    </header>

    <div class="essay-grid">
      <aside class="essay-side" aria-label="Article navigation and metadata">
        <div class="essay-outline">
          <p>Outline</p>
          {
            outline.length > 0 ? (
              <nav>
                {outline.map((heading) => (
                  <a
                    class:list={[heading.depth === 3 && "is-child"]}
                    href={`#${heading.slug}`}
                    data-outline-link={heading.slug}
                  >
                    {heading.text}
                  </a>
                ))}
              </nav>
            ) : (
              <span>No headings yet.</span>
            )
          }
        </div>
        <div class="essay-facts">
          <p>About this post</p>
          <ul>
            <li>{readingMinutes} min read</li>
            <li>Published {formattedDate}</li>
            {post.data.updated && (
              <li>
                Updated {post.data.updated.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </li>
            )}
          </ul>
        </div>
      </aside>

      <div class="essay-content">
        <Content />
      </div>
    </div>

    <footer class="essay-end">
      <a href="/blog">Back to archive</a>
      <a href="/">Home</a>
    </footer>
  </article>

  <script>
    const outlineLinks = [...document.querySelectorAll("[data-outline-link]")];
    const headings = outlineLinks
      .map((link) => {
        const id = link.getAttribute("data-outline-link");
        const heading = id ? document.getElementById(id) : null;
        return heading ? { link, heading } : null;
      })
      .filter(Boolean);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (!visible) return;

        headings.forEach((item) => {
          item?.link.classList.toggle("is-active", item.heading === visible.target);
        });
      },
      { rootMargin: "-18% 0px -65% 0px", threshold: [0.1, 0.35, 0.65] },
    );

    headings.forEach((item) => item && observer.observe(item.heading));
  </script>
</MainLayout>
