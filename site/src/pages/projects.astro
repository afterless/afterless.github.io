---
import SubpageLayout from "../layouts/SubpageLayout.astro";

const projects = [
  {
    title: "Personal research site",
    status: "active",
    description:
      "A hand-shaped Astro site for research notes, essays, and project traces. The design language uses a sparse threshold background on the homepage and quiet ledger surfaces elsewhere.",
    tags: ["Astro", "design systems", "writing"],
    link: "https://github.com/afterless",
  },
  {
    title: "Georgia Tech AI Safety Initiative",
    status: "community",
    description:
      "Co-founded a student group for technical AI safety reading, education, and project formation at Georgia Tech.",
    tags: ["AI safety", "education", "organizing"],
    link: "/",
  },
  {
    title: "Future-token representations",
    status: "research",
    description:
      "Prior work investigating how language models encode future-token structure with sparse autoencoder tools.",
    tags: ["interpretability", "SAEs", "LLMs"],
    link: "/blog",
  },
];
---

<SubpageLayout title="projects — afterless" description="Projects and research traces by Ayush Panda.">
  <article class="subpage-stack">
    <header class="subpage-hero">
      <p class="subpage-kicker">Projects</p>
      <h1>Work surfaces and public traces.</h1>
      <p>
        A compact ledger of things I have built, organized, or researched. This
        page should eventually point to writeups rather than explain everything
        itself.
      </p>
    </header>

    <section class="route-board" aria-label="Project route">
      {
        projects.map((project, index) => (
          <a
            href={project.link}
            target={project.link.startsWith("http") ? "_blank" : undefined}
            rel={project.link.startsWith("http") ? "noopener noreferrer" : undefined}
            class="route-step"
          >
            <span class="route-index">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <div class="route-meta">
                <span>{project.status}</span>
                <span>{project.tags.join(" / ")}</span>
              </div>
              <h2>{project.title}</h2>
              <p>{project.description}</p>
            </div>
          </a>
        ))
      }
    </section>
  </article>
</SubpageLayout>
