---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="about — afterless" description="About afterless.">
  <article class="prose">
    <h1
      class="text-3xl font-semibold tracking-tight text-neutral-900 dark:text-white sm:text-4xl"
    >
      About
    </h1>

    <div class="mt-8 space-y-6 text-neutral-600 dark:text-neutral-300 leading-relaxed">
      <p class="text-lg">
        Hey, I'm <strong class="text-neutral-900 dark:text-white font-medium">afterless</strong>.
      </p>

      <p>
        This is my corner of the internet. I'm interested in building things,
        breaking things, and understanding how things work at a fundamental level.
      </p>

      <h2
        class="!mt-12 text-xl font-semibold text-neutral-900 dark:text-white"
      >
        Interests
      </h2>

      <ul class="list-none space-y-2 pl-0">
        <li class="flex items-start gap-3">
          <span class="mt-1 block h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
          <span>Software engineering & systems programming</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 block h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
          <span>AI & machine learning</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 block h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
          <span>Touhou & bullet hell games</span>
        </li>
      </ul>

      <h2
        class="!mt-12 text-xl font-semibold text-neutral-900 dark:text-white"
      >
        This Site
      </h2>

      <p>
        Built with <a
          href="https://astro.build"
          class="text-accent underline underline-offset-2 decoration-accent/30 hover:decoration-accent transition-colors"
          target="_blank"
          rel="noopener noreferrer">Astro</a
        > and <a
          href="https://tailwindcss.com"
          class="text-accent underline underline-offset-2 decoration-accent/30 hover:decoration-accent transition-colors"
          target="_blank"
          rel="noopener noreferrer">Tailwind CSS</a
        >. The landing page features a custom danmaku particle system
        and a design language inspired by
        <a
          href="https://en.wikipedia.org/wiki/Bad_Apple!!"
          class="text-accent underline underline-offset-2 decoration-accent/30 hover:decoration-accent transition-colors"
          target="_blank"
          rel="noopener noreferrer">Bad Apple!!</a
        > — all contrast, no clutter.
      </p>

      <h2
        class="!mt-12 text-xl font-semibold text-neutral-900 dark:text-white"
      >
        Contact
      </h2>

      <p>
        Find me on <a
          href="https://github.com/afterless"
          class="text-accent underline underline-offset-2 decoration-accent/30 hover:decoration-accent transition-colors"
          target="_blank"
          rel="noopener noreferrer">GitHub</a
        >.
      </p>
    </div>
  </article>
</MainLayout>
