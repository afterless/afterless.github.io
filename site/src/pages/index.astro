---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Ayush Panda">
  <div class="relative min-h-screen bg-neutral-950 text-neutral-300">
    <canvas
      id="danmaku"
      class="pointer-events-none fixed inset-0 z-0"
      aria-hidden="true"></canvas>

    <div class="relative z-10 mx-auto max-w-2xl px-6 pt-12 pb-24 sm:px-10 sm:pt-20">
      <!-- Name -->
      <h1 class="text-2xl text-white" style="font-family: 'Inter', sans-serif; font-weight: 600; letter-spacing: 0.03em;">
        Ayush Panda
      </h1>

      <!-- Contact -->
      <div class="mt-3 text-sm text-neutral-500">
        apanda38 [at] gatech [dot] edu
      </div>
      <div class="mt-1.5 text-sm text-neutral-500">
        <a href="https://linkedin.com/in/ayushpanda1029" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-300">LinkedIn</a>,
        <a href="https://github.com/afterless" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-300">GitHub</a>
      </div>

      <!-- Bio -->
      <div class="mt-8 space-y-4 leading-relaxed">
        <p>
          Hi! I'm Ayush. As of winter 2026, I am a MATS scholar in Francis Rhys
          Ward's stream, working on AI control settings for automated AI R&D.
          Outside of MATS, I am pursuing my MS in Computer Science at Georgia
          Tech, where I co-founded the AI Safety Initiative.
        </p>

        <p>
          I am interested in AI safety, interpretability, and understanding the
          internal mechanisms of large language models. Previously, I investigated
          how LLMs encode future tokens using sparse autoencoders at SPAR, and
          taught ML safety as a TA for the Center for AI Safety. I have also
          worked as a software engineer at AWS.
        </p>
      </div>


    </div>
  </div>
</Layout>

<script>
  const canvas = document.getElementById("danmaku") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  type Shape = "circle" | "diamond" | "star" | "rice";
  const shapes: Shape[] = ["circle", "diamond", "star", "rice"];

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    life: number;
    decay: number;
    size: number;
    shape: Shape;
  }

  let particles: Particle[] = [];
  let time = 0;
  let lastEmit = 0;
  let patternTimer = 0;
  let patternIndex = 0;
  const patterns = ["spiral", "ring", "flower"] as const;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function emit() {
    const pattern = patterns[patternIndex];
    const count = 8;
    const shape = shapes[Math.floor(Math.random() * shapes.length)];
    const ox = canvas.width * 0.6;
    const oy = canvas.height * 0.45;

    for (let i = 0; i < count; i++) {
      let angle: number;
      let speed: number;

      switch (pattern) {
        case "spiral":
          angle = (i / count) * Math.PI * 2 + time * 0.4;
          speed = 0.35;
          break;
        case "ring":
          angle = (i / count) * Math.PI * 2;
          speed = 0.45;
          break;
        case "flower":
          angle = (i / count) * Math.PI * 2;
          speed = 0.3 + Math.sin(i * 3) * 0.15;
          break;
      }

      particles.push({
        x: ox,
        y: oy,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        life: 1,
        decay: 0.0012 + Math.random() * 0.001,
        size: 0.8 + Math.random() * 0.8,
        shape,
      });
    }
  }

  function drawStar(x: number, y: number, r: number) {
    ctx.beginPath();
    for (let i = 0; i < 8; i++) {
      const rad = i % 2 === 0 ? r : r * 0.4;
      const a = (i * Math.PI) / 4 - Math.PI / 2;
      if (i === 0) ctx.moveTo(x + Math.cos(a) * rad, y + Math.sin(a) * rad);
      else ctx.lineTo(x + Math.cos(a) * rad, y + Math.sin(a) * rad);
    }
    ctx.closePath();
    ctx.fill();
  }

  function drawParticle(p: Particle) {
    ctx.fillStyle = "#fff";
    switch (p.shape) {
      case "circle":
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fill();
        break;
      case "diamond":
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(Math.PI / 4);
        ctx.fillRect(-p.size, -p.size, p.size * 2, p.size * 2);
        ctx.restore();
        break;
      case "star":
        drawStar(p.x, p.y, p.size * 1.3);
        break;
      case "rice":
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(Math.atan2(p.vy, p.vx));
        ctx.beginPath();
        ctx.ellipse(0, 0, p.size * 1.6, p.size * 0.4, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
        break;
    }
  }

  let lastTime = 0;
  let started = false;

  function loop(now: number) {
    if (!started) { lastTime = now; started = true; }
    const dt = Math.min((now - lastTime) / 1000, 0.05);
    lastTime = now;
    time += dt;
    lastEmit += dt;
    patternTimer += dt;

    if (patternTimer > 5) {
      patternIndex = (patternIndex + 1) % patterns.length;
      patternTimer = 0;
    }

    if (lastEmit > 0.7) {
      emit();
      lastEmit = 0;
    }

    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.x += p.vx;
      p.y += p.vy;
      p.life -= p.decay;
      if (p.life <= 0) particles.splice(i, 1);
    }

    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const p of particles) {
      ctx.globalAlpha = p.life * 0.08;
      drawParticle(p);
    }
    ctx.globalAlpha = 1;

    requestAnimationFrame(loop);
  }

  resize();
  window.addEventListener("resize", resize);
  requestAnimationFrame(loop);
</script>
